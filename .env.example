# MCP Server Configuration
MCP_API_KEY=your-secret-api-key-here
MCP_PORT=8080

# Logging Configuration
LOG_LEVEL=INFO

# Timezone Configuration
# defaults to UTC
TIMEZONE=America/Sao_Paulo

# Media Download Configuration
# Enable/disable automatic media download when messages arrive
MEDIA_AUTO_DOWNLOAD_ENABLED=true

# Enable/disable automatic media download from HistorySync events
# HistorySync can trigger hundreds of downloads simultaneously causing 403 errors
# Set to false to only download media from new incoming messages
MEDIA_AUTO_DOWNLOAD_FROM_HISTORY=true

# Maximum file size for auto-download in MB (0 = unlimited)
MEDIA_AUTO_DOWNLOAD_MAX_SIZE_MB=10

# Comma-separated list of media types to auto-download
# Options: image, video, audio, document, sticker, ptt, gif
MEDIA_AUTO_DOWNLOAD_TYPES=image,audio,sticker,video,document

# Webhook Configuration (optional)
# Primary webhook URL - message events will be sent here automatically
# Leave empty to disable webhooks
WEBHOOK_URL=

# Advanced webhook settings
# Maximum number of delivery retry attempts (default: 3)
WEBHOOK_MAX_RETRIES=3

# HTTP request timeout in seconds (default: 10)
WEBHOOK_TIMEOUT_SECONDS=10

# Number of concurrent webhook delivery workers (default: 3)
WEBHOOK_WORKER_POOL_SIZE=3

# @claude Trigger Configuration (optional)
# Enable the @claude trigger — headless Claude Code CLI replies when someone
# mentions @claude in a WhatsApp message. Owner always allowed; other users
# must be added via the add_trusted_user MCP tool.
CLAUDE_TRIGGER_ENABLED=false

# Path to the Claude CLI binary (use absolute path on Windows)
CLAUDE_PATH=claude

# Model override passed to Claude CLI (e.g. sonnet, opus, haiku). Empty = default.
CLAUDE_MODEL=

# Max spend per invocation in USD. Empty = no budget limit.
CLAUDE_MAX_BUDGET_USD=1.00

# Max seconds to wait for a Claude response before killing the subprocess.
CLAUDE_TIMEOUT_SECONDS=300

# Prior-turn context (input + cache_creation + cache_read tokens) above this
# threshold triggers an auto-compaction pass on the next @claude trigger:
# summarize the existing session, then mint a fresh session seeded with the
# summary and the full trust-framing prompt.
CLAUDE_COMPACT_THRESHOLD_TOKENS=120000

# Model used for the summarization sub-call during auto-compaction.
CLAUDE_COMPACT_MODEL=haiku

# Display name for your own (account-owner) messages in the transcript and
# prompt framing. Set this to your first name for natural prompts (e.g.
# Messages from "Alice" are from the WhatsApp account owner). Default: Owner
OWNER_NAME=Owner

# memory-index vault to silently consult on new @claude sessions to load
# background context about chat participants. Leave empty to disable the
# mandatory memory-fetch block in the prompt entirely.
MEMORY_VAULT=